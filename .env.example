# ─── Banco de dados (Neon PostgreSQL) ────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# ─── NextAuth ─────────────────────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""

# ─── Azure AD (Microsoft Login) ───────────────────────────────────────────────
AZURE_AD_CLIENT_ID=""
AZURE_AD_CLIENT_SECRET=""
AZURE_AD_TENANT_ID=""

# ─── E-mail (Microsoft Graph API — usa as credenciais do Azure AD acima) ─────
# Caixa de envio (deve ter Mail.Send concedido via Application Access Policy)
EMAIL_FROM=""

# ─── Cron / Vercel Cron ───────────────────────────────────────────────────────
# Token usado pela rota /api/cron/reminders pra validar que a chamada é legítima
# Gere com: node -e "console.log(require('crypto').randomBytes(24).toString('base64url'))"
CRON_SECRET=""

# ─── Busca de passagens (provider opcional) ──────────────────────────────────
# Quando vazio ou sem credenciais abaixo, a busca roda em modo DEMONSTRAÇÃO
# (dados fictícios). Para usar dados reais, crie uma conta em
# https://developers.amadeus.com e preencha as chaves. Sandbox é gratuito.
FLIGHT_SEARCH_PROVIDER="" # "amadeus" ou vazio para demo
AMADEUS_CLIENT_ID=""
AMADEUS_CLIENT_SECRET=""
AMADEUS_ENV="test"        # "test" (sandbox grátis) ou "production"
