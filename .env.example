# ─── Banco de dados (Neon PostgreSQL) ────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# ─── NextAuth ─────────────────────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""

# ─── Azure AD (Microsoft Login) ───────────────────────────────────────────────
AZURE_AD_CLIENT_ID=""
AZURE_AD_CLIENT_SECRET=""
AZURE_AD_TENANT_ID=""

# ─── E-mail (Microsoft Graph API — usa as credenciais do Azure AD acima) ─────
# Caixa de envio (deve ter Mail.Send concedido via Application Access Policy)
EMAIL_FROM=""

# ─── Cron / Vercel Cron ───────────────────────────────────────────────────────
# Token usado pela rota /api/cron/reminders pra validar que a chamada é legítima
# Gere com: node -e "console.log(require('crypto').randomBytes(24).toString('base64url'))"
CRON_SECRET=""

# ─── Busca de passagens ───────────────────────────────────────────────────────
# A aba /flight-search hoje opera em dois modos combinados:
#   1) Botões que abrem os consolidadores (Google Flights, Skyscanner, Kayak,
#      Kiwi, Decolar) com a busca preenchida — preços reais, zero custo.
#   2) Prévia com dados fictícios da DemoProvider para visualizar o layout.
# Não há API paga configurada. Caso futuramente seja adicionado um provedor
# real, use FLIGHT_SEARCH_PROVIDER e as credenciais correspondentes.
