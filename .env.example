# ─── Banco de dados (Neon PostgreSQL) ────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# ─── NextAuth ─────────────────────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""

# ─── Azure AD (Microsoft Login) ───────────────────────────────────────────────
AZURE_AD_CLIENT_ID=""
AZURE_AD_CLIENT_SECRET=""
AZURE_AD_TENANT_ID=""

# ─── E-mail (Microsoft Graph API — usa as credenciais do Azure AD acima) ─────
# Caixa de envio (deve ter Mail.Send concedido via Application Access Policy)
EMAIL_FROM=""

# ─── Cron / Vercel Cron ───────────────────────────────────────────────────────
# Token usado pela rota /api/cron/reminders pra validar que a chamada é legítima
# Gere com: node -e "console.log(require('crypto').randomBytes(24).toString('base64url'))"
CRON_SECRET=""

# ─── Busca de passagens ───────────────────────────────────────────────────────
# A aba /flight-search usa por padrão o DecolarScraperProvider: faz scraping
# ao vivo da Decolar via Playwright e retorna top-N ordenado por preço.
#
# Funciona em desenvolvimento local (Chrome real instalado). Em produção
# Vercel ainda cai em bloqueio por anti-bot headless — ver src/lib/flight-scraper/README.md.
#
# FLIGHT_SEARCH_PROVIDER=demo  # Opcional — força DemoProvider (dados fictícios)
#                              # para testar a UI sem depender da Decolar.
# CHROME_EXECUTABLE_PATH=""    # Opcional — caminho do Chrome se não estiver no default.
# FLIGHT_SCRAPER_HEADED=1      # Opcional — abre janela visível do navegador (debug).
