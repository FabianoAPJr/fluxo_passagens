# ===== Banco de Dados (Neon.tech) =====
# Copie a connection string do painel do Neon
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# ===== Azure AD =====
# Obtidos no portal.azure.com → App registrations
AZURE_AD_CLIENT_ID="seu-client-id-aqui"
AZURE_AD_CLIENT_SECRET="seu-client-secret-aqui"
AZURE_AD_TENANT_ID="seu-tenant-id-aqui"

# ===== NextAuth =====
# Gere com: openssl rand -base64 32
NEXTAUTH_SECRET="gere-um-secret-aleatorio-aqui"
# Em dev: http://localhost:3000 | Em prod: https://seu-app.vercel.app
NEXTAUTH_URL="http://localhost:3000"
